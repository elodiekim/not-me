{
  "expo": {
    "name": "NotMe",
    "slug": "notme-app",
    "version": "1.0.0",
    "scheme": "notme",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/logo/app-icon.png",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "NotMe uses your location to show nearby missions and their distance."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo/app-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ]
    ]
  }
}
