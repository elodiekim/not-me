{
  "expo": {
    "name": "NotMe",
    "slug": "notme-app",
    "version": "1.0.0",
    "scheme": "notme",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
